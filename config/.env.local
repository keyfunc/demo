# 服务配置
SERVICE_NAME=server-api
SERVER_PORT=8080

# 日志配置：LOGGER_LEVEL 可选 debug、info、warn、error；LOGGER_FORMAT 可选 text、json
LOGGER_LEVEL=debug
LOGGER_FORMAT=text

# PostgreSQL 配置：Docker Compose 内 DB_HOST 使用服务名 postgres
DB_HOST=106.52.180.97
DB_PORT=5432
DB_USER=young
DB_PASSWORD=ly123456
DB_NAME=demo
DB_SSLMODE=disable

# Redis 配置：Docker Compose 内 REDIS_ADDR 使用服务名 redis；REDIS_PASSWORD 为空表示不启用密码
REDIS_ADDR=redis:6379
REDIS_PASSWORD=ly123456
REDIS_DB=0
